generator client {
  provider = "prisma-client"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}


model webhook {
  id String @id 
  url String @unique
  createdAt DateTime @default(now())
  webhookResponses response[]
}

model response {
  id String @id @default(cuid())
  webhookId String
  type String
  createdAt DateTime @default(now())
  headers Json
  body Json
  webhook webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)
}